# =====================================================
# Configurações do Painel Mirante Céu Azul
# Copie este arquivo para .env e preencha os valores.
# =====================================================

# Porta do servidor (padrão: 3000)
PORT=3000

# Segredo usado pra assinar os tokens JWT.
# Gere algo aleatório forte. Exemplo (Linux/Mac):
#   openssl rand -hex 32
# No Windows, pode usar: https://generate-secret.vercel.app/32
JWT_SECRET=

# Credenciais do administrador
ADMIN_USERNAME=felipe
# Hash bcrypt da senha. Gere rodando:
#   cd server && npm run gerar-senha
# Cole o resultado aqui SEM aspas.
ADMIN_PASSWORD_HASH=

# =====================================================
# Google Calendar (opcional — se em branco, roda em modo MOCK)
# =====================================================
# ID do calendário (encontrado em Configurações do calendário no Google Calendar).
# Algo como: abc123xyz@group.calendar.google.com
GOOGLE_CALENDAR_ID=

# JSON da conta de serviço (em uma linha só, escapando aspas se necessário).
# Veja o passo a passo no README, seção "Google Calendar".
GOOGLE_SERVICE_ACCOUNT_JSON=

# =====================================================
# WhatsApp do sítio (sem +, sem espaços)
# Ex: 5511999999999
# =====================================================
WHATSAPP_NUMBER=5511999999999

# =====================================================
# Web Push (notificações de lembrete)
# Gere as chaves rodando:
#   cd server && npm run gerar-vapid
# Cole o resultado aqui. Sem essas chaves, push fica desabilitado.
# =====================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:contato@miranteceuazul.com.br

# =====================================================
# Webhook do n8n (Sol pode notificar o painel quando criar reservas)
# Defina um secret aleatório forte. A Sol vai enviar no header X-Webhook-Secret.
# Sem isso, o endpoint /api/n8n/webhook fica desabilitado.
# =====================================================
N8N_WEBHOOK_SECRET=
